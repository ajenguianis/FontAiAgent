 
    "vue": {
      "composition-api": {
        "title": "Migration vers la Composition API",
        "prompt": "Aide-moi à migrer ce composant Vue.js de l'Options API vers la Composition API. Voici le code actuel:\n\n{code}\n\nGénère une version avec la Composition API qui:\n1. Utilise ref() et reactive() pour l'état\n2. Utilise computed() pour les propriétés calculées\n3. Utilise onMounted(), onUnmounted() pour les lifecycle hooks\n4. Utilise watch() pour les watchers\n5. Suit les meilleures pratiques Vue 3",
        "examples": [
          {
            "before": "export default {\n  data() {\n    return {\n      count: 0\n    }\n  },\n  computed: {\n    doubleCount() {\n      return this.count * 2\n    }\n  },\n  methods: {\n    increment() {\n      this.count++\n    }\n  }\n}",
            "after": "import { ref, computed } from 'vue'\n\nexport default {\n  setup() {\n    const count = ref(0)\n    const doubleCount = computed(() => count.value * 2)\n    \n    const increment = () => {\n      count.value++\n    }\n    \n    return {\n      count,\n      doubleCount,\n      increment\n    }\n  }\n}"
          }
        ]
      },
      "pinia": {
