    "angular": {
      "standalone": {
        "title": "Migration vers les Standalone Components",
        "prompt": "Convertis ce composant Angular en standalone component. Le composant doit:\n1. Utiliser standalone: true\n2. Importer les dépendances nécessaires\n3. Définir les inputs/outputs\n4. Utiliser OnPush change detection si approprié\n5. Suivre les meilleures pratiques Angular 17+",
        "examples": [
          {
            "before": "@Component({\n  selector: 'app-user-card',\n  templateUrl: './user-card.component.html',\n  styleUrls: ['./user-card.component.scss']\n})\nexport class UserCardComponent {\n  @Input() user: User;\n  @Output() userClick = new EventEmitter<User>();\n}",
            "after": "import { Component, Input, Output, EventEmitter, ChangeDetectionStrategy } from '@angular/core';\nimport { CommonModule } from '@angular/common';\nimport { User } from '../models/user.model';\n\n@Component({\n  selector: 'app-user-card',\n  standalone: true,\n  imports: [CommonModule],\n  templateUrl: './user-card.component.html',\n  styleUrls: ['./user-card.component.scss'],\n  changeDetection: ChangeDetectionStrategy.OnPush\n})\nexport class UserCardComponent {\n  @Input() user!: User;\n  @Output() userClick = new EventEmitter<User>();\n}"
          }
        ]
      },
      "signals": {
        "title": "Migration vers Angular Signals",
        "prompt": "Convertis ce service Angular pour utiliser les Signals au lieu des Observables. Le service doit:\n1. Utiliser signal() pour l'état\n2. Utiliser computed() pour les valeurs calculées\n3. Utiliser effect() pour les effets de bord\n4. Exposer les signaux via des getters\n5. Suivre les patterns Signals",
        "examples": [
          {
            "template": "import { Injectable, signal, computed, effect } from '@angular/core';\nimport { User } from '../models/user.model';\n\n@Injectable({\n  providedIn: 'root'\n})\nexport class UserService {\n  private users = signal<User[]>([]);\n  private selectedUserId = signal<number | null>(null);\n  \n  // Computed values\n  public readonly selectedUser = computed(() => {\n    const userId = this.selectedUserId();\n    return userId ? this.users().find(u => u.id === userId) : null;\n  });\n  \n  public readonly userCount = computed(() => this.users().length);\n  \n  // Actions\n  setUsers(users: User[]) {\n    this.users.set(users);\n  }\n  \n  selectUser(userId: number) {\n    this.selectedUserId.set(userId);\n  }\n  \n  constructor() {\n    // Effects\n    effect(() => {\n      console.log('Selected user changed:', this.selectedUser());\n    });\n  }\n}"
          }
        ]
      },
