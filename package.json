{
    "name": "expert-frontend-agent",
    "version": "3.0.0",
    "description": "Expert Frontend Agent - Assistant IA spécialisé en développement frontend avec intégration IDE native",
    "main": "dist/agent/index.js",
    "bin": {
      "frontend-expert": "dist/agent/index.js",
      "install-ide-agent": "install-ide-agent.js"
    },
    "scripts": {
      "start": "ts-node src/agent/index.ts",
      "build": "tsc",
      "dev": "ts-node --watch src/agent/index.ts",
      "test": "jest",
      "test:watch": "jest --watch",
      "test:install": "node test-installation.js",
      "lint": "eslint src/**/*.ts",
      "lint:fix": "eslint src/**/*.ts --fix",
      "install-ide": "node install-ide-agent.js",
      "install-global": "node install-global.js",
      "analyze": "ts-node src/agent/index.ts .",
      "audit": "ts-node src/agent/index.ts . audit",
      "enhance": "ts-node src/agent/index.ts . enhance",
      "chat": "ts-node src/agent/chat-agent.ts",
      "ide": "ts-node src/agent/ide-integration.ts"
    },
    "keywords": [
      "frontend",
      "ai",
      "agent",
      "vue",
      "react",
      "angular",
      "nuxt",
      "next",
      "design",
      "ux",
      "ui",
      "performance",
      "accessibility",
      "ide",
      "chat",
      "assistant"
    ],
    "author": "Anis Ajengui",
    "license": "MIT",
    "dependencies": {
      "fs-extra": "^11.1.1",
      "uuid": "^9.0.1",
      "chalk": "^5.3.0",
      "inquirer": "^9.2.12",
      "ora": "^7.0.1"
    },
    "devDependencies": {
      "@types/fs-extra": "^11.0.4",
      "@types/uuid": "^9.0.7",
      "@types/inquirer": "^9.0.7",
      "@types/jest": "^29.5.8",
      "@types/node": "^20.8.10",
      "@typescript-eslint/eslint-plugin": "^6.10.0",
      "@typescript-eslint/parser": "^6.10.0",
      "eslint": "^8.53.0",
      "jest": "^29.7.0",
      "ts-jest": "^29.1.1",
      "ts-node": "^10.9.1",
      "typescript": "^5.2.2"
    },
    "engines": {
      "node": ">=16.0.0"
    },
    "repository": {
      "type": "git",
      "url": "https://github.com/ajenguianis/FontAiAgent.git"
    },
    "bugs": {
      "url": "https://github.com/ajenguianis/FontAiAgent/issues"
    },
    "homepage": "https://github.com/ajenguianis/FontAiAgent#readme"
  }