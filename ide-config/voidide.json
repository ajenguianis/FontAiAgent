{
    "tasks": [
        {
            "name": "Run FrontAgent Job",
            "command": "ts-node src/scripts/front-agent-job.ts",
            "args": [
                "--project"
            ],
            "description": "Exécuter le workflow itératif d’optimisation frontend"
        },
        {
            "name": "Run UX Analysis",
            "command": "node src/scripts/ux-analyzer.js",
            "args": [
                "--project"
            ],
            "description": "Analyser l’UX/UI du projet"
        },
        {
            "name": "Track Changes",
            "command": "ts-node src/scripts/track-changes.ts",
            "args": [],
            "description": "Suivre et sauvegarder les fichiers modifiés"
        },
        {
            "name": "Rollback",
            "command": "bash src/scripts/rollback.sh",
            "args": [
                "${input:timestamp}",
                "${input:tech}",
                "${input:file}"
            ],
            "description": "Restaurer les fichiers à partir d’une sauvegarde"
        },
        {
            "name": "Clear Backups",
            "command": "bash src/scripts/clear-backups.sh",
            "args": [
                "${input:timestamp}",
                "${input:tech}"
            ],
            "description": "Supprimer les sauvegardes"
        }
    ],
    "inputs": [
        {
            "id": "timestamp",
            "type": "prompt",
            "description": "Timestamp de la sauvegarde (ex. 20250629-1304, vide pour tous)",
            "default": ""
        },
        {
            "id": "tech",
            "type": "prompt",
            "description": "Technologie à restaurer/supprimer (Twig, CSS, JS, vide pour tous)",
            "default": ""
        },
        {
            "id": "file",
            "type": "prompt",
            "description": "Fichier spécifique à restaurer (ex. templates/base.html.twig, vide pour tous)",
            "default": ""
        }
    ]
}